# config.env.example - Template for personal configuration
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#   nano config.env
#
# config.env is gitignored - your personal details never get committed.
# This example file IS committed - it shows others what values are needed.

# Your identity
DOTFILES_USER_NAME="Your Full Name"
DOTFILES_USER_EMAIL="you@example.com"

# Your GitHub username (used in clone URLs and README)
DOTFILES_GITHUB_USERNAME="yourusername"

# Your Windows username (used in file paths like C:\Users\<name>)
DOTFILES_WINDOWS_USERNAME="yourwindowsusername"

# Your first project name (created as a VS Code workspace config)
# Format: p###-project-name (e.g. p008-arcane-predictive)
DOTFILES_FIRST_PROJECT="p001-my-first-project"
